controller:
  url: https://unifi.example.com      # Base URL of the UniFi Network application
  api_key: YOUR_API_KEY_HERE          # API key for read-only controller access

devices:
  ssh:
    user: YOUR_SSH_USER               # Device SSH Authentication username from UniFi
    # password: YOUR_SSH_PASSWORD     # omit for SSH key/agent auth; set for password-based login (requires sshpass)

sites:
  default:
    # UniFi site name as shown by the controller / Network application.
    # RF environment used to derive the TX target corridor (default: residential).
    #   open          large open spaces, retail    (n=2.2, TX_LO≈−72)
    #   residential   homes, apartments            (n=2.8, TX_LO≈−73)  ← default
    #   office        office buildings              (n=3.0, TX_LO≈−74)
    #   obstructed    concrete, brick, multi-wall   (n=4.0, TX_LO≈−76)
    #   <number>      custom value                  (typically ~2.0 to 4.0; e.g. 3.5 → TX_LO≈−75)
    environment: residential

    wlans:
      YOUR-WIFI: general_5g           # WLAN name in UniFi -> shipped profile name from profiles.yaml

    neighbors:                        # AP name -> list of APs clients are expected to roam to
      AP1: [AP2]
      AP2: [AP1, AP3]
      AP3: [AP2]
